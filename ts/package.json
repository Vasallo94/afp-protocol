{
  "name": "afp-core",
  "version": "0.2.0",
  "description": "Agent Feedback Protocol — TypeScript implementation (validation, identity, ownership, redaction)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
