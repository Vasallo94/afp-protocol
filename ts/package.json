    "url": "git+https://github.com/Vasallo94/afp-protocol.git",
    "directory": "ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "packageurl-js": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
